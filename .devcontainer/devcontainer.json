// Opens this course in GitHub Codespaces with the exact same Postgres
// service a local reader gets from `docker compose up -d` — not a
// simplified stand-in. See docker-compose.extend.yml for why a second
// compose file layers a dev-tooling container on top of the project's own
// compose.yaml instead of editing it directly.
{
  "name": "sqlalchemy-mastery",

  "dockerComposeFile": ["../compose.yaml", "docker-compose.extend.yml"],
  "service": "app",
  "workspaceFolder": "/workspaces/sqlalchemy",

  "features": {
    "ghcr.io/va-h/devcontainers-features/uv:1": {}
  },

  "postCreateCommand": "uv sync",

  "forwardPorts": [5439]
}
